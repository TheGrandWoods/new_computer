// ─────────────────────────────────────────────
//  PLUGIN IMPORTS
// ─────────────────────────────────────────────

ai        = {import:ai-text-plugin}
image     = {import:text-to-image-plugin}
kv        = {import:kv-plugin}
remember  = {import:remember-plugin}
dexie     = {import:dexie-plugin}
fetch     = {import:super-fetch-plugin}


// ─────────────────────────────────────────────
//  GENERATOR METADATA
// ─────────────────────────────────────────────

title
  AI Text & Image Studio (Plugin)

description
  A full-featured AI studio with text generation, image creation, prompt enhancement,
  memory, KV-based user profiles, Dexie persistence, theme-aware UI, and advanced panels.

author
  Mosberg

version
  2.0.0

tags
  ai, text, image, plugin, kv, dexie, memory, theme, advanced, studio

category
  AI Utilities


// ─────────────────────────────────────────────
//  GLOBAL CONFIG / CONSTANTS
// ─────────────────────────────────────────────

defaultModel
  gpt-4o-mini

defaultImageModel
  flux-dev

kvNamespace_userProfiles
  aiStudio_userProfiles

kvNamespace_settings
  aiStudio_settings

dexieDbName
  aiStudio_db

dexieStore_sessions
  sessions

dexieStore_gallery
  gallery

themeKey
  aiStudio_theme


// ─────────────────────────────────────────────
//  SIDEBAR UI
// ─────────────────────────────────────────────
//
//  High-level layout:
//  - Mode selector (Text / Image / Mixed)
//  - Prompt input
//  - Settings button
//  - Panels: Prompt Enhancer, AI Text Enhancer, Image Gallery
// ─────────────────────────────────────────────

sidebar
  section "Mode"
    field mode select
      Text
      Image
      Mixed

  section "Prompt"
    field userPrompt textarea
      Enter your idea, description, or request here...

  section "Actions"
    button "Generate" command:generate
    button "Enhance Prompt" command:open_prompt_enhancer
    button "AI Text Enhancer" command:open_text_enhancer
    button "Image Gallery" command:open_gallery
    button "Settings" command:open_settings

  section "Profile"
    field profileName text
      default: "guest"
    button "Load Profile" command:load_profile
    button "Save Profile" command:save_profile


// ─────────────────────────────────────────────
//  CUSTOM COMMANDS
// ─────────────────────────────────────────────

command:generate
  if {mode} == "Text"
    -> generate_text
  else if {mode} == "Image"
    -> generate_image
  else
    -> generate_mixed

command:open_prompt_enhancer
  -> panel_prompt_enhancer

command:open_text_enhancer
  -> panel_text_enhancer

command:open_gallery
  -> panel_image_gallery

command:open_settings
  -> panel_settings

command:load_profile
  -> load_user_profile

command:save_profile
  -> save_user_profile


// ─────────────────────────────────────────────
//  CORE GENERATION COMMANDS
// ─────────────────────────────────────────────

command:generate_text
  enhancedPrompt = {call:build_final_prompt}
  result = {ai:complete
    model:{defaultModel}
    prompt:{enhancedPrompt}
  }
  output
    {result}

command:generate_image
  enhancedPrompt = {call:build_final_prompt}
  img = {image:generate
    model:{defaultImageModel}
    prompt:{enhancedPrompt}
  }
  output
    [imageGenerated]
    {img}

command:generate_mixed
  enhancedPrompt = {call:build_final_prompt}
  txt = {ai:complete
    model:{defaultModel}
    prompt:{enhancedPrompt}
  }
  img = {image:generate
    model:{defaultImageModel}
    prompt:{enhancedPrompt}
  }
  output
    [Text]
    {txt}

    [Image]
    {img}


// ─────────────────────────────────────────────
//  PROMPT ENHANCER MODULE
// ─────────────────────────────────────────────

panel_prompt_enhancer
  title
    Prompt Enhancer
  description
    Refine and expand your prompt before generation.

  field basePrompt textarea
    default:{userPrompt}

  field stylePreset select
    Neutral
    Creative
    Cinematic
    Technical
    RPG Narrative

  button "Apply" command:apply_prompt_enhancer

command:apply_prompt_enhancer
  enhanced = {ai:complete
    model:{defaultModel}
    prompt:
      Enhance the following prompt in a {stylePreset} style.
      Keep it concise but vivid and usable for both text and image generation.

      Prompt:
      "{basePrompt}"
  }
  set userPrompt = {enhanced}
  output
    [promptUpdated]
    {enhanced}


// ─────────────────────────────────────────────
//  AI TEXT ENHANCER PANEL
// ─────────────────────────────────────────────

panel_text_enhancer
  title
    AI Text Enhancer
  description
    Improve, rewrite, or transform existing text.

  field sourceText textarea
    Enter text to enhance...

  field enhancementMode select
    Improve clarity
    Make more descriptive
    Shorten
    Expand
    Formalize
    Casual

  button "Enhance" command:run_text_enhancer

command:run_text_enhancer
  result = {ai:complete
    model:{defaultModel}
    prompt:
      Mode: {enhancementMode}
      Transform the following text accordingly, preserving core meaning.

      Text:
      "{sourceText}"
  }
  output
    [enhancedText]
    {result}


// ─────────────────────────────────────────────
//  IMAGE GALLERY SYSTEM (Dexie-backed)
// ─────────────────────────────────────────────

panel_image_gallery
  title
    Image Gallery
  description
    View and manage generated images stored in Dexie.

  button "Load Gallery" command:gallery_load
  button "Clear Gallery" command:gallery_clear

command:gallery_save
  // Save last image + prompt to Dexie
  {dexie:put
    db:{dexieDbName}
    store:{dexieStore_gallery}
    value:
      {
        prompt:{userPrompt},
        timestamp:{time},
        // You can store image URL or ref if plugin supports it
        imageRef:{img}
      }
  }

command:gallery_load
  items = {dexie:getAll
    db:{dexieDbName}
    store:{dexieStore_gallery}
  }
  output
    [galleryItems]
    {items}

command:gallery_clear
  {dexie:clear
    db:{dexieDbName}
    store:{dexieStore_gallery}
  }
  output
    [galleryCleared]


// ─────────────────────────────────────────────
//  ADVANCED SETTINGS PANEL
// ─────────────────────────────────────────────

panel_settings
  title
    Advanced Settings
  description
    Configure models, behavior, and theme.

  section "Models"
    field settings_model text
      default:{defaultModel}
    field settings_imageModel text
      default:{defaultImageModel}

  section "Behavior"
    field settings_temperature number
      default:0.7
      min:0
      max:1
      step:0.05

  section "Theme"
    field settings_theme select
      System
      Light
      Dark

  button "Save Settings" command:settings_save

command:settings_save
  {kv:set
    namespace:{kvNamespace_settings}
    key:"model"
    value:{settings_model}
  }
  {kv:set
    namespace:{kvNamespace_settings}
    key:"imageModel"
    value:{settings_imageModel}
  }
  {kv:set
    namespace:{kvNamespace_settings}
    key:"temperature"
    value:{settings_temperature}
  }
  {kv:set
    namespace:{kvNamespace_settings}
    key:"theme"
    value:{settings_theme}
  }

  // Apply theme immediately if supported
  {theme:set
    key:{themeKey}
    value:{settings_theme}
  }

  output
    [settingsSaved]
    [themeApplied]


// ─────────────────────────────────────────────
//  USER PROFILES VIA KV NAMESPACES
// ─────────────────────────────────────────────

command:load_user_profile
  profile = {kv:get
    namespace:{kvNamespace_userProfiles}
    key:{profileName}
  }
  if {profile} != null
    set userPrompt = {profile.prompt}
    set mode       = {profile.mode}
    output
      [profileLoaded]
      Name: {profileName}
      Mode: {mode}
  else
    output
      [profileNotFound]
      "{profileName}" has no saved profile yet.

command:save_user_profile
  {kv:set
    namespace:{kvNamespace_userProfiles}
    key:{profileName}
    value:
      {
        prompt:{userPrompt},
        mode:{mode}
      }
  }
  output
    [profileSaved]
    Name: {profileName}


// ─────────────────────────────────────────────
//  THEME MEMORY (REMEMBER PLUGIN)
// ─────────────────────────────────────────────

init
  // Load remembered theme preference
  savedTheme = {remember:get key:{themeKey}}
  if {savedTheme} != null
    {theme:set key:{themeKey} value:{savedTheme}}

command:settings_save
  // (Extend existing command to also remember theme)
  {remember:set
    key:{themeKey}
    value:{settings_theme}
  }
  // rest of logic already above


// ─────────────────────────────────────────────
//  SUPER_FETCH API CALLS (Example Hook)
// ─────────────────────────────────────────────
//
//  Example: call an external API to enrich prompt context.
// ─────────────────────────────────────────────

command:fetch_context
  ctx = {fetch:get url:"https://example.com/context-api" query: {q:{userPrompt}}}
  output
    [fetchedContext]
    {ctx}


// ─────────────────────────────────────────────
//  PROMPT BUILD PIPELINE (FINAL MERGE POINT)
// ─────────────────────────────────────────────

call:build_final_prompt
  // Load settings
  modelSetting = {kv:get namespace:{kvNamespace_settings} key:"model"}
  tempSetting  = {kv:get namespace:{kvNamespace_settings} key:"temperature"}

  finalPrompt =
    You are an AI assistant in the "AI Text & Image Studio" plugin.
    Use the following user prompt, enhanced if available, and respect the current mode.

    Mode: {mode}
    User prompt:
    "{userPrompt}"

  return {finalPrompt}
