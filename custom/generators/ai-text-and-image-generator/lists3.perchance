ai        = {import:ai-text-plugin}
image     = {import:text-to-image-plugin}
kv        = {import:kv-plugin}
remember  = {import:remember-plugin}
fetch     = {import:super-fetch-plugin}

// Custom Dexie plugin
dexie = {
  init: {
    run:
      {kv:set namespace:"dexie_meta" key:"{db}_{store}" value:"[]"}
  },
  put: {
    run:
      existing = {kv:get namespace:"dexie_meta" key:"{db}_{store}"}
      arr = {json:parse existing}
      newArr = {json:stringify {arr.push {value}}}
      {kv:set namespace:"dexie_meta" key:"{db}_{store}" value:{newArr}}
  },
  getAll: {
    run:
      existing = {kv:get namespace:"dexie_meta" key:"{db}_{store}"}
      return {json:parse existing}
  },
  clear: {
    run:
      {kv:set namespace:"dexie_meta" key:"{db}_{store}" value:"[]"}
  }
}


// ─────────────────────────────────────────────
//  METADATA
// ─────────────────────────────────────────────

title
  AI Text & Image Studio (Plugin)

description
  Full Perchance plugin with AI text, image generation, prompt enhancement,
  Dexie-style storage, user profiles, theme memory, and advanced UI panels.

author
  Mosberg

version
  2.0.0


// ─────────────────────────────────────────────
//  CONFIG
// ─────────────────────────────────────────────

defaultModel
  gpt-4o-mini

defaultImageModel
  flux-dev

kvNamespace_userProfiles
  aiStudio_userProfiles

kvNamespace_settings
  aiStudio_settings

dexieDbName
  aiStudio_db

dexieStore_gallery
  gallery

themeKey
  aiStudio_theme


// ─────────────────────────────────────────────
//  SIDEBAR UI
// ─────────────────────────────────────────────

sidebar
  section "Mode"
    field mode select
      Text
      Image
      Mixed

  section "Prompt"
    field userPrompt textarea
      Enter your idea...

  section "Actions"
    button "Generate" command:generate
    button "Enhance Prompt" command:open_prompt_enhancer
    button "AI Text Enhancer" command:open_text_enhancer
    button "Image Gallery" command:open_gallery
    button "Settings" command:open_settings

  section "Profile"
    field profileName text
      default:"guest"
    button "Load Profile" command:load_profile
    button "Save Profile" command:save_profile


// ─────────────────────────────────────────────
//  COMMAND ROUTER
// ─────────────────────────────────────────────

command:generate
  if {mode} == "Text"
    -> generate_text
  else if {mode} == "Image"
    -> generate_image
  else
    -> generate_mixed


// ─────────────────────────────────────────────
//  GENERATION COMMANDS
// ─────────────────────────────────────────────

command:generate_text
  p = {call:build_final_prompt}
  result = {ai:complete model:{defaultModel} prompt:{p}}
  output {result}

command:generate_image
  p = {call:build_final_prompt}
  img = {image:generate model:{defaultImageModel} prompt:{p}}
  output {img}

command:generate_mixed
  p = {call:build_final_prompt}
  txt = {ai:complete model:{defaultModel} prompt:{p}}
  img = {image:generate model:{defaultImageModel} prompt:{p}}
  output
    {txt}
    {img}


// ─────────────────────────────────────────────
//  PROMPT ENHANCER PANEL
// ─────────────────────────────────────────────

panel_prompt_enhancer
  title Prompt Enhancer
  field basePrompt textarea default:{userPrompt}
  field stylePreset select
    Neutral
    Creative
    Cinematic
    Technical
    RPG Narrative
  button "Apply" command:apply_prompt_enhancer

command:apply_prompt_enhancer
  enhanced = {ai:complete
    model:{defaultModel}
    prompt:
      Enhance this prompt in a {stylePreset} style:
      "{basePrompt}"
  }
  set userPrompt = {enhanced}
  output {enhanced}


// ─────────────────────────────────────────────
//  AI TEXT ENHANCER PANEL
// ─────────────────────────────────────────────

panel_text_enhancer
  title AI Text Enhancer
  field sourceText textarea
  field enhancementMode select
    Improve clarity
    Make more descriptive
    Shorten
    Expand
    Formalize
    Casual
  button "Enhance" command:run_text_enhancer

command:run_text_enhancer
  result = {ai:complete
    model:{defaultModel}
    prompt:
      Mode: {enhancementMode}
      Transform this text:
      "{sourceText}"
  }
  output {result}


// ─────────────────────────────────────────────
//  IMAGE GALLERY (Dexie)
// ─────────────────────────────────────────────

panel_image_gallery
  title Image Gallery
  button "Load Gallery" command:gallery_load
  button "Clear Gallery" command:gallery_clear

command:gallery_save
  {dexie:put db:{dexieDbName} store:{dexieStore_gallery} value:
    {
      prompt:{userPrompt},
      timestamp:{time},
      imageRef:{img}
    }
  }

command:gallery_load
  items = {dexie:getAll db:{dexieDbName} store:{dexieStore_gallery}}
  output {items}

command:gallery_clear
  {dexie:clear db:{dexieDbName} store:{dexieStore_gallery}}
  output Gallery cleared


// ─────────────────────────────────────────────
//  SETTINGS PANEL (with theme memory)
// ─────────────────────────────────────────────

panel_settings
  title Settings
  field settings_model text default:{defaultModel}
  field settings_imageModel text default:{defaultImageModel}
  field settings_temperature number default:0.7 min:0 max:1 step:0.05
  field settings_theme select
    System
    Light
    Dark
  button "Save Settings" command:settings_save

command:settings_save
  {kv:set namespace:{kvNamespace_settings} key:"model" value:{settings_model}}
  {kv:set namespace:{kvNamespace_settings} key:"imageModel" value:{settings_imageModel}}
  {kv:set namespace:{kvNamespace_settings} key:"temperature" value:{settings_temperature}}
  {remember:set key:{themeKey} value:{settings_theme}}
  output Settings saved


// ─────────────────────────────────────────────
//  USER PROFILES
// ─────────────────────────────────────────────

command:load_profile
  profile = {kv:get namespace:{kvNamespace_userProfiles} key:{profileName}}
  if {profile} != null
    set userPrompt = {profile.prompt}
    set mode = {profile.mode}
    output Profile loaded
  else
    output Profile not found

command:save_profile
  {kv:set namespace:{kvNamespace_userProfiles} key:{profileName} value:
    {
      prompt:{userPrompt},
      mode:{mode}
    }
  }
  output Profile saved


// ─────────────────────────────────────────────
//  SUPER-FETCH API CALL EXAMPLE
// ─────────────────────────────────────────────

command:fetch_context
  ctx = {fetch:get url:"https://example.com/api" query:{q:{userPrompt}}}
  output {ctx}


// ─────────────────────────────────────────────
//  PROMPT PIPELINE
// ─────────────────────────────────────────────

call:build_final_prompt
  return:
    Final prompt:
    Mode: {mode}
    "{userPrompt}"
