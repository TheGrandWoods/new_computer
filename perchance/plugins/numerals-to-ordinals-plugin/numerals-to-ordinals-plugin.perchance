$output(n) =>
  if(n == "") return "";
	n = Number(n);
	if(isNaN(n)) return "(error: you passed a non-number to the numerals-to-ordinals plugin)";
  if(n == 0) return "zeroth";
	let s = n+"";
	s1 = s.slice(-1);
	s2 = s.slice(-2);
	if(s2 === "11") return n+"th";
	if(s2 === "12") return n+"th";
	if(s2 === "13") return n+"th";
	if(s1 === "1") return n+"st";
	if(s1 === "2") return n+"nd";
	if(s1 === "3") return n+"rd";
  return n+"th";
