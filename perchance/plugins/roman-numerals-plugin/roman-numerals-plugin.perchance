// Credit: https://stackoverflow.com/a/41358305/11950764
$output(num) =>
  num = num.evaluateItem;
	console.log(num, 6);
  let roman = {
    M: 1000,
    CM: 900,
    D: 500,
    CD: 400,
    C: 100,
    XC: 90,
    L: 50,
    XL: 40,
    X: 10,
    IX: 9,
    V: 5,
    IV: 4,
    I: 1
  };
  let str = '';
	try {
  for (var i of Object.keys(roman)) {
    var q = Math.floor(num / roman[i]);
    num -= q * roman[i];
    str += i.repeat(q);
  } } catch(e) { debugger; }
  return str;
